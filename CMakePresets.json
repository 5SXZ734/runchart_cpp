{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-vcpkg",
      "displayName": "Windows / vcpkg x64",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build/windows-vcpkg",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "C:/WORK/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "ninja-vcpkg",
      "displayName": "Ninja / vcpkg x64",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ninja-vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "C:/WORK/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vcpkg-release",
      "configurePreset": "windows-vcpkg",
      "configuration": "Release"
    },
    {
      "name": "ninja-vcpkg-release",
      "configurePreset": "ninja-vcpkg"
    }
  ]
}
