{
	"version": 6,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 25,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "windows-vcpkg",
			"displayName": "Windows / vcpkg x64",
			"generator": "Visual Studio 18 2026",
			"binaryDir": "${sourceDir}/build/windows-vcpkg",
			"cacheVariables": {
				"CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
				"VCPKG_TARGET_TRIPLET": "x64-windows"
			}
		},
		{
			"name": "wsl-release",
			"displayName": "WSL Ubuntu Release",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/wsl-release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			},
			"vendor": {
				"microsoft.com/VisualStudioSettings/CMake/1.0": {
					"hostOS": [
						"Linux"
					]
				}
			}
		}
	],
	"buildPresets": [
		{
			"name": "windows-vcpkg-release",
			"configurePreset": "windows-vcpkg",
			"configuration": "Release"
		},
		{
			"name": "wsl-release-build",
			"configurePreset": "wsl-release"
		}
	]
}

